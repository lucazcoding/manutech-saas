# =============================================================================
# MANUTECH — Variáveis de Ambiente para Testes E2E com Docker Local
# =============================================================================
# Usado automaticamente pelos testes em tests/e2e/ quando o stack Docker
# está rodando localmente (docker compose up -d).
#
# O banco e o Redis ficam dentro dos containers, mas expõem portas no localhost
# da sua máquina Windows. Este arquivo aponta para essas portas expostas.
#
# Pydantic Settings mapeia DATABASE_URL e REDIS_URL para os atributos de configuração.
# =============================================================================

# Banco de dados PostgreSQL — container expõe na porta 5432 do localhost
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/manutech

# Redis local do Docker — autenticado com a senha configurada no .env principal
REDIS_URL=redis://default:gQAAAAAAAiV5AAIgcDFjYTkxYjcwZmU2ODk0ODkwODQ3MTU0MWIyNzVjOWQzNQ@localhost:6379/0
