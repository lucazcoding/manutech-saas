JWT_ACCESS_TOKEN_EXPIRE_HOURS=1  # [DEV]
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7  # [DEV]


# -----------------------------------------------------------------------------
# SUPABASE (apenas se STORAGE_PROVIDER=supabase)
#
# O backend Python NÃO usa o SDK do Supabase para o banco — usa psycopg3 direto.
# Supabase URL e Service Key só são necessários se usar o Supabase Storage
# para armazenar os anexos das ordens de serviço.
# -----------------------------------------------------------------------------
SUPABASE_URL=https://kbpssakythvksthjibtq.supabase.co                    # [OPERADOR] ex: https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY= sb_publishable_jT3fHkXZFIFSsp7br-aphw_ZVyk11sm      # [OPERADOR] service_role key — NUNCA expor no frontend
SUPABASE_SENHA_DB= banco@n8nA8                                                              # [OPERADOR] senha do usuário do banco no Supabase (usado para DATABASE_URL)

# -----------------------------------------------------------------------------
# STORAGE — Armazenamento de anexos das OS (PDFs, imagens)
#
# Escolha UM provedor e preencha as variáveis correspondentes.
# Decisão deve ser alinhada com o operador antes de implementar upload.
#
# Opção A — Supabase Storage (requer SUPABASE_URL + SUPABASE_SERVICE_KEY acima)
# Opção B — AWS S3 ou compatível (Cloudflare R2, MinIO)
# Opção C — Disco local (APENAS desenvolvimento, não usar em produção)
# -----------------------------------------------------------------------------
STORAGE_PROVIDER= supabase           # [OPERADOR] local | supabase | s3

# Opção A — Supabase Storage
STORAGE_BUCKET=attachments       # [DEV] nome do bucket no Supabase Storage

# Opção B — AWS S3 (ou compatível)
AWS_ACCESS_KEY_ID=               # [OPERADOR]
AWS_SECRET_ACCESS_KEY=           # [OPERADOR]
AWS_S3_BUCKET=manutech-attachments  # [OPERADOR]
AWS_S3_REGION=us-east-1          # [OPERADOR]

# Opção C — Disco local
STORAGE_LOCAL_PATH=/app/uploads  # [DEV] montar volume Docker para persistência


# -----------------------------------------------------------------------------
# RATE LIMITING / CACHE
# -----------------------------------------------------------------------------
LOGIN_MAX_ATTEMPTS=5             # [DEV] tentativas de login por IP (janela de 15 min)
LOGIN_WINDOW_SECONDS=900         # [DEV] 15 minutos em segundos
STATS_CACHE_TTL_SECONDS=30       # [DEV] TTL do cache de GET /orders/stats


# -----------------------------------------------------------------------------
# WEBSOCKET (Notification Service)
# -----------------------------------------------------------------------------
WS_MAX_CONNECTIONS_PER_USER=5    # [DEV] conexões WebSocket simultâneas por usuário


# -----------------------------------------------------------------------------
# PORTAS DOS SERVIÇOS (referência — docker-compose usa valores fixos)
# -----------------------------------------------------------------------------
AUTH_SERVICE_PORT=8001           # [DEV]
ASSET_SERVICE_PORT=8002          # [DEV]
ORDER_SERVICE_PORT=8003          # [DEV]
INVENTORY_SERVICE_PORT=8004      # [DEV]
FINANCE_SERVICE_PORT=8005        # [DEV]
NOTIFICATION_SERVICE_PORT=8006   # [DEV]


# =============================================================================
# VARIÁVEIS POR SERVIÇO
#
# Cada serviço possui seu próprio services/<nome>/.env.example com apenas as
# variáveis que ele precisa. Este arquivo raiz é usado pelo docker-compose
# para provisionar os containers de infraestrutura (db, redis) e serve como
# referência global de todas as variáveis do projeto.
# =============================================================================
