# =============================================================================
# MANUTECH — Variáveis de Ambiente (Raiz / docker-compose)
# =============================================================================
# Copie este arquivo para .env e preencha os valores antes de rodar.
#
# Legenda:
#   [OPERADOR] — Preenchido pelo responsável de infra. NUNCA tem valor padrão seguro.
#   [DEV]      — Valor padrão para desenvolvimento local. Pode usar como está.
#   [GERADO]   — Gerado uma vez e entregue ao operador para armazenar com segurança.
#
# NUNCA comite o arquivo .env com valores reais no repositório.
# =============================================================================


# -----------------------------------------------------------------------------
# AMBIENTE
# -----------------------------------------------------------------------------
ENVIRONMENT=development          # [DEV] development | staging | production


# -----------------------------------------------------------------------------
# POSTGRESQL — Docker local (dev) / Supabase (produção)
#
# Em dev:  usado pelo container `db` no docker-compose e pelos serviços Python.
# Em prod: DATABASE_URL aponta para a connection string do Supabase.
#          POSTGRES_* só são usados se rodar o container local de banco.
# -----------------------------------------------------------------------------
POSTGRES_DB=manutech                                                        # [DEV]
POSTGRES_USER=postgres                                                      # [DEV]
POSTGRES_PASSWORD=postgres

# Connection string completa (asyncpg) — usada por todos os serviços + migrations
# Em dev local: substituir SENHA pelo valor de POSTGRES_PASSWORD acima
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/manutech   # [DEV LOCAL]


# -----------------------------------------------------------------------------
# REDIS — Docker local (dev) / Redis Cloud ou Upstash (produção)
#
# Usos: rate limiting de login · cache de stats (TTL 30s) · Pub/Sub de eventos
# Redis sem senha NÃO deve ir para produção.
# -----------------------------------------------------------------------------
REDIS_PASSWORD=gQAAAAAAAiV5AAIgcDFjYTkxYjcwZmU2ODk0ODkwODQ3MTU0MWIyNzVjOWQzNQ                    # [OPERADOR] OBRIGATÓRIO
REDIS_URL=rediss://default:gQAAAAAAAiV5AAIgcDFjYTkxYjcwZmU2ODk0ODkwODQ3MTU0MWIyNzVjOWQzNQ@crucial-martin-140665.upstash.io:6379          # [OPERADOR]


# -----------------------------------------------------------------------------
# JWT — RS256 (par de chaves RSA 2048 bits)
#
# Como gerar:
#   openssl genrsa -out jwt_private.pem 2048
#   openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
#
# Converter para single-line (necessário para env var):
#   cat jwt_private.pem | tr '\n' '\\n'
#   cat jwt_public.pem  | tr '\n' '\\n'
#
# ATENÇÃO:
#   JWT_PRIVATE_KEY — APENAS no Auth Service (porta 8001)
#   JWT_PUBLIC_KEY  — em TODOS os serviços (verificação de token)
# -----------------------------------------------------------------------------
