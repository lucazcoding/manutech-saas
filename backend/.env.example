# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=manutech
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here

# Connection string usada pelos serviços (aponta para o container "db")
DATABASE_URL=postgresql+asyncpg://postgres:your_strong_password_here@db:5432/manutech

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://:your_redis_password_here@redis:6379/0

# ── JWT (RS256) ───────────────────────────────────────────────────────────────
# Gerar com: openssl genrsa -out jwt_private.pem 2048
#            openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
#            cat jwt_private.pem | tr '\n' '\n'
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ── Supabase Storage (para uploads de anexos) ─────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_SENHA_DB= *****
STORAGE_BUCKET=attachments
