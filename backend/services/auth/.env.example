# =============================================================================
# Auth Service — porta 8001
# Único serviço que possui JWT_PRIVATE_KEY.
# =============================================================================

ENVIRONMENT=development                                                          # [DEV]
SERVICE_PORT=8001                                                                # [DEV]

# Banco de Dados
DATABASE_URL=postgresql+psycopg://postgres:SENHA@db:5432/manutech               # [OPERADOR]

# Redis (rate limiting de login + pub/sub)
REDIS_URL=redis://:SENHA@redis:6379/0                                            # [OPERADOR]
REDIS_PASSWORD=                                                                  # [OPERADOR]

# JWT — chave PRIVADA apenas neste serviço
JWT_PRIVATE_KEY=                 # [GERADO] "-----BEGIN RSA PRIVATE KEY-----\n..."
JWT_PUBLIC_KEY=                  # [GERADO] "-----BEGIN PUBLIC KEY-----\n..."
JWT_ACCESS_TOKEN_EXPIRE_HOURS=1  # [DEV]
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7  # [DEV]

# Rate Limiting de Login
LOGIN_MAX_ATTEMPTS=5             # [DEV]
LOGIN_WINDOW_SECONDS=900         # [DEV] 15 minutos

# Supabase Storage (não usado pelo Auth Service mas requerido pelo SharedSettings)
SUPABASE_URL=                    # [OPERADOR]
SUPABASE_SERVICE_KEY=            # [OPERADOR]
STORAGE_BUCKET=attachments       # [DEV]
